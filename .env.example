# ─────────────────────────────────────────────────────────────
# Configuración de Supabase — Dra. Reyna Massiel
# Copia este archivo a .env.local y rellena los valores reales.
# .env.local está en .gitignore: los secretos NUNCA se suben al repo.
# ─────────────────────────────────────────────────────────────

# Público — seguro de exponer al navegador (protegido por RLS en el servidor).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# ⚠️  SECRETO — SOLO servidor. Sin prefijo NEXT_PUBLIC_. Nunca en el cliente ni en el repo.
# Otorga acceso total ignorando RLS: trátalo como la llave maestra.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# URL base del sitio (para enlaces de correo de recuperación de contraseña).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
